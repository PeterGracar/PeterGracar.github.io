<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for p in site.pages %}
  {%- unless p.no_index or p.url contains "sitemap" %}
  <url>
    <loc>{{ site.url }}{{ p.url }}</loc>
  </url>
  {%- endunless %}
{%- endfor %}
</urlset>
